[run]
source = .
omit =
    .venv/*
    venv/*
    tests/*
    setup.py
    setup_project.sh
    process_logs/*
    */migrations/*
    */tests/*

[report]
# Exclude lines from coverage
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    class .*Protocol.*:

# Ignore import errors for optional dependencies
ignore_errors = True

precision = 2

[html]
directory = htmlcov
