# DigitalAuditor Configuration

# Audit Profile: testing, production, development
# - testing: Mock Ollama, minimal logging, in-memory vector store
# - production: Real Ollama, INFO logging, persistent vector store
# - development: Real Ollama, DEBUG logging, JSON output for analysis
AUDIT_PROFILE=development

# Ollama LLM Configuration
# Base URL where Ollama is running
OLLAMA_BASE_URL=http://localhost:11434

# Model name to use for audits
OLLAMA_MODEL=digital-auditor-cisa

# Timeout for Ollama requests (seconds)
OLLAMA_TIMEOUT=30

# Maximum retries for failed Ollama requests
OLLAMA_MAX_RETRIES=3

# External APIs
# Tavily API key for web search functionality
TAVILY_API_KEY=your_tavily_key_here

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Path to text log file
LOG_FILE=audit.log

# Enable JSON output for process mining (development/production)
LOG_JSON=false

# Knowledge Base Configuration
# These are typically not overridden unless using non-standard paths
# KNOWLEDGE_RAW_DOCS=./knowledge/raw_docs
# CHROMA_DB_PATH=./chroma_db

# Development/Debugging
# Enable debug mode for additional output
DEBUG=false
